#import "../literature-template.typ": work

#work(
  title: "Utrpení mladého Werthera",
  author: "Johann Wolfgang von Goethe",
  year: 1774,
  characteristics: (
    obsah: [
      Jedná se o román v dopisech (*epistolární* román). Je psán v ich-formě prostřednictvím dopisů hlavního hrdiny Werthera.
    ],
    utvary: [
      Román v dopisech, což umožňuje hluboký vhled do psychiky hlavní postavy. Použití lyrických pasáží, které vyjadřují Wertherovy emoce a pocity.

      V díle se objevují romantické prvky, jako je idealizace přírody, důraz na subjektivní prožívání a konflikt mezi jedincem a společností.
    ],
    name-meaning: [
      Název "Utrpení mladého Werthera" odkazuje na hlavní téma díla, kterým je emocionální a psychické utrpení mladého muže jménem Werther. Tento název zdůrazňuje tragický osud hlavního hrdiny, který je zasažen nešťastnou láskou a neschopností najít své místo ve společnosti.
      _V první polovině je Werter docela šťastný._
    ],
    tema: [
      Hlavním tématem je nešťastná láska, která vede k tragickému konci. Werther se zamiluje do Lottky, která je však zasnoubená s jiným mužem. Tato láska je zdrojem jeho utrpení a nakonec i sebevraždy.

      Dalším důležitým tématem je konflikt mezi jedincem a společností. Werther se cítí nepochopený a izolovaný od společnosti, což přispívá k jeho psychickému rozpadu.
    ],
  ),
  literary-context: (
    umelecke-smer: [
      Dílo je zařazováno do období preromantismu a raného romantismu. Vzniklo na přechodu klasicismu k romantismu. Odpor k racionálnímu osvícenství a důraz na citové prožívání jsou charakteristickými rysy tohoto období. *Hnutí Sturm und Drang*, které zdůrazňovalo individualismus a emocionální expresi, mělo na dílo velký vliv.

      Časové vymezení: 1774, kdy bylo dílo poprvé publikováno.
    ],
    historicke-souvislosti: [
      - Německo bylo v 18. století roztříštěno na množství malých knížectví.
      - Stavovská společnost s rigidními sociálními strukturami omezovala osobní svobodu jednotlivců.
      - Osvícenství kladlo důraz na rozum, vědu a pokrok, což kontrastovalo s emocionálním a subjektivním přístupem Werthera.
      - Román oslovil především mladou generaci, která:
        - se cítila nepochopená a svázaná konvencemi
        - hledala smysl života v citech a autenticitě
      - Goethe se roku 1772 zamiloval do Charlotty Buffové, která byla zasnoubena (a později provdána) za jiného muže.
      - Goetheho přítel Karl Wilhelm Jerusalem spáchal sebevraždu z nešťastné lásky a společenského zklamání.
      - Werther předznamenává romantismus, i když sám ještě patří do předromantické fáze.
    ],
    soucasnici: [
      - *Friedrich Schiller*
        - Jedním z předních představitelů hnutí Sturm und Drang, jehož díla také zdůrazňovala emocionální intenzitu a individualismus.
        - *Óda na radost* -- oslava lidské svobody a bratrství.
        - Studium medicíny, později vojenský lékař, spolupráce s Goethem.
      - *Jean Jacques Rousseau* -- přispívání do encyklopedií.
        - Nucený exil v zahraničí.
        - Důraz na přirozenost a cit v lidském životě, což ovlivnilo romantické myšlení.
        - *Emil aneb O výchově* -- studie o výchově a přirozeném vývoji člověka.
    ],
    autoruv-zivot: [
      - Johann Wolfgang von Goethe (1749-1832) byl německý básník, dramatik, prozaik a státník.
      - Studoval práva na univerzitě ve Frankfurtu a Lipsku, ale brzy se začal věnovat literatuře a umění.
      - Byl významnou postavou německého literárního hnutí Sturm und Drang.
      - Jeho dílo zahrnuje širokou škálu žánrů, včetně poezie, dramatu, románu a vědeckých prací.
      - Byl také zapojen do politiky a sloužil jako ministr ve Weimaru.
      - Goethe vydal dílo *Utrpení mladého Werthera* v roce 1774, nějaký čas poté, co sám prožil nešťastnou lásku, která ho očividně docela zasáhla.
      _Fun fact: Goethe strávil spoustu času v Čechách, dokonce více času než v Itálii._
    ],
    dalsi-dila: [
      - *Faust* -- Goetheho nejznámější dílo, které zkoumá téma lidské touhy po poznání a smyslu života.
      - *Viléma Meistera léta učednická* -- o životní cestě za uměním a zmoudřením.
      - Trilogie *Vášně* -- stárnoucí muž glazuje 17ti letou borku.
    ],
  ),
  kompozice: [
    Děj probíhá chronologicky prostřednictvím dopisů, které Werther píše svému příteli Wilhelmovi. Román je rozdělen do 2 částí. Dopisy jsou datované a navazují na tvoří časovou osu.
  ],
  obsah-dila: [
    Utrpení mladého Werthera vypráví příběh citlivého mladého muže Werthera, který přichází na venkov, kde se zamiluje do Charlotty (Lotte), dívky již zasnoubené s rozumným a společensky uznávaným Albertem; Werther, neschopný potlačit své city ani se přizpůsobit společenským konvencím, postupně propadá stále hlubšímu vnitřnímu rozporu mezi vášní a realitou, cítí se odcizen společnosti, selhává v profesním životě a jeho láska se mění v bezvýchodné utrpení, které vyústí v rozhodnutí ukončit vlastní život, čímž román končí jako tragický obraz konfliktu jedince sám se sebou i se světem.
  ],
  postavy: [
    - *Werther* -- hlavní postava, mladý muž citlivé povahy, který se zamiluje do Lottky.
    - *Lottka* -- objekt Wertherovy lásky, zasnoubená s Albertem, představuje ideál krásy a ctnosti.
    - *Albert* -- Lottčin snoubenec, rozumný a stabilní muž, kontrast k Wertherovi.
    - *Wilhelm* -- Wertherův přítel, kterému jsou dopisy adresovány.
  ],
  vypravecsky-zpusob: [
    Dílo je v podobě dopisů (které Werther adresuje Wilhelmovi), je tedy užita ich-forma vyprávění.
    Krom dopisů občasně vystupuje i "vydavatel" (není to actual vydavatel), který dopisy komentuje.
  ],
  jazyk-dila: [
    Dílo by původně napsáno v němčině. V českém překladu je použita
    spisovná čeština s občasnými archaickými výrazy.
  ],
  ohlas-dila: [
    Často se říká, že dílo spustilo lavinu sebevražd mezi mladými čtenáři, kteří se ztotožnili s Wertherem. Tento fenomén je znám jako "Wertherův efekt" (viz _Copycat suicide_ na Wikipedia). Tento fakt však není nijak oficiálně podložen.

    Dílo se stalo známým po celé Evropě skoro přes noc. Napoleon Bonaparte považoval tohoto dílo za jedno z nejlepších z evropské literatury. Spousta mladých lidí se začla oblékat podle toho, jak byl Werther v dopisech popisován.
  ],
  ctenar: [
    Další klasické dílo, o kterém by měl každý alespoň trochu slyšet.
  ],
)