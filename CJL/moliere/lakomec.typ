#import "../literature-template.typ": work

#work(
  title: "Lakomec",
  author: "Moliére",
  year: 1668,

  characteristics: (
    obsah: [
      Drama — próza
    ],
    utvary: [
      *Komedie* — postavy jsou nositeli jedné výrazné vlastnosti (lakomství, chytrost), pocházejí z měšťanstva. Skrze smích kritizuje lidské slabosti a společenské nešvary. Inspirováno antickou *Komedií o hrnci* Plauta. Prvek *deus ex machina* — náhlé vyřešení situace odhalením Anselmovy totožnosti.
    ],
    name-meaning: [
      Příběh lakomého Harpagona — jeho jméno z latinského _harpago_ = kořistník, lupič. Název přímo pojmenovává hlavní postavu i ústřední téma.
    ],
    tema: [
      Kritika chorobné touhy po penězích. Peníze jako vášeň vylučující člověka z normálního života, deformující přirozené vztahy a city. Molière varuje, že bohatství samo o sobě štěstí nepřináší — vede k osamělosti, podezíravosti a rozpadu rodinných pout.

      *Motivy:* lakomství, láska, krádež, zápletka otce a syna o tutéž ženu, rodinné vztahy
    ],
  ),

  literary-context: (
    umelecke-smer: [
      *Klasicismus* (17.–18. stol.) — z lat. _classicus_ = vynikající, vzorný. Vznikl ve Francii za vlády Ludvíka XIV., navazuje na antiku a renesanci. Vyžaduje přesný řád, pevná pravidla, vyváženost a soulad s rozumem. Touhy jedince ustupují před společenskými normami.

      Žánry se dělí na:
      - *Vysoké* (óda, epos, tragédie) — život vysokých vrstev, čerpáno z antiky
      - *Nízké* (komedie, fraška, bajka, satira) — život měšťanstva, ze soudobého života

      Lakomec patří mezi nízké žánry.
    ],
    historicke-souvislosti: [
      Dílo vzniklo roku 1668 v období absolutistické monarchie Ludvíka XIV. ve Francii. Klasicismus předchází Velké francouzské revoluci (1789). Molière psal pod královskou ochranou — jeho satira mířila na pokrytectví šlechty a církve.
    ],
    soucasnici: [
      - Jean Racine — tragédie _Faidra_
      - Pierre Corneille — tragédie _Cid_
      - Jean de la Fontaine — bajky (_Comedia dell'arte_)
      - Carlo Goldoni — _Sluha dvou pánů_
      - Daniel Defoe — anglická próza
    ],
    autoruv-zivot: [
      *Jean-Baptiste Poquelin* (1622–1673), francouzský herec, spisovatel a dramatik. Proti vůli rodičů (měl se stát notářem) se vzdal otcova úřadu a stal se kočovným hercem. Vystoupil před králem Ludvíkem XIV. a stal se ředitelem královského divadla v Paříži. Věnoval se převážně nízkým žánrům. Typické znaky jeho tvorby: odvážná kritika společenských poměrů, mísení žánrů, zesměšňování pokrytectví a snobské morálky.
    ],
    dalsi-dila: [
      - _Tartuffe_ (veršované) — náboženské pokrytectví
      - _Misantrop_
      - _Zdravý a nemocný_
      - _Popleta_
      - _Podvodník_
    ],
  ),

  kompozice: [
    *5 dějství (aktů)*, chronologická kompozice. Dodrženy *3 jednoty* klasicismu: jednota místa (dům Harpagona v Paříži), jednota času (1 den), jednota děje (1 zápletka). Komediální zápletky, situační komika, častá nedorozumění, která se na konci rozpletou.
  ],

  obsah-dila: [
    Starý lichvář *Harpagon* chce svou dceru Elišku provdat za bohatého starce Anselma a sám se oženit s mladou Marianou — do níž je však zamilován jeho syn Kleantes. Kleantovi pomáhá mazaný sluha *Čipera*, který najde Harpagonovy zakopané peníze (30 000 zlatých) a použije je jako páku. Výměnou za vrácení peněz se Harpagon vzdá Mariany. Situaci vyřeší Anselmovo odhalení — je to bohatý hrabě z Neapole a otec Mariany i Valéra. Zaplatí obě svatby, nepožaduje věno. Harpagon souhlasí — dostane zpět poklad. Všichni jsou spokojeni, zejména Harpagon.
  ],

  postavy: [
    - *Harpagon* — ~60letý lichvář a vdovec. Chamtivý, bezcitný, chorobně podezíravý. Peníze schovává po celém domě. Ztráta peněz = ztráta smyslu života. Tragikomická postava.
    - *Kleantes* — Harpagonův syn, chytrý a podnikavý. Otcova láska k penězům se mu příčí.
    - *Eliška* — Harpagonova dcera, spravedlivá, upřímná. Tajně zasnoubena s Valérem.
    - *Mariana* — chudá, hodná dívka, zamilovaná do Kleanta.
    - *Valér* — správce domu, hraje sluhu, aby byl blíž Elišce. Z dobré rodiny (syn hraběte Anselma).
    - *Čipera (Štika)* — mazaný sluha Kleanta, vychází z antické tradice chytrého sluhy. Klíčová postava pro rozuzlení.
    - *Anselm* — bohatý starec, ve skutečnosti hrabě z Neapole, otec Mariany a Valéra.
  ],

  vypravecsky-zpusob: [
    Drama — *bez vypravěče*. Střídání ich-forem v dialozích. Velmi živé a vtipné dialogy, monology (Harpagonův slavný monolog o ukradených penězích), řečnické otázky.
  ],

  jazyk-dila: [
    Spisovný jazyk, historismy. Situační komika, ironie, nadsázka, hyperbola, metafory. Citoslovce (_achich_), personifikace (k penězům), zdrobněliny (_penízky_), přechodníky (_chytaje_), věty zvolací. Dialog i monolog, přímá řeč.
  ],

  ohlas-dila: [
    Molièrovy hry jsou dodnes živé. Po Shakespearovi označován za největšího světového dramatika. Filmové zpracování z roku 1980 (Louis de Funès v hlavní roli). Mnohé divadelní adaptace — např. Divadlo na Vinohradech (Miloš Kopecký).
  ],
)