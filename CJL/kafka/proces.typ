#import "../literature-template.typ": work

#work(
  title: "Proces",
  author: "Franz Kafka",
  year: "1925 (napsáno 1914)",
  characteristics: (
    obsah: [Próza.],
    utvary: [Epika, psychologický román (experimentálně modernistický), absurdní literatura.],
    name-meaning: [
      Román z prostředí soudů. Názvem je označen marný proces hlavního hrdiny Josefa K., kterého neúprosně drtí zkorumpovaný a absurdní byrokratický systém. 
    ],
    tema: [
      - *Hlavní*: Proces Josefa K. a jeho marný boj s nejasnými soudními praktikami.
      - *Vedlejší*: Kritika odlidštění byrokratických institucí moderní společnosti, nebezpečí zmechanizování člověka a života, zesměšnění soudů, měšťáctví, život malíře, příběh o Lence, rodina Josefa K.
      - *Myšlenka*: Válka člověka se sebou samým a s byrokracií v době míru. Podobenství o anonymní zlé síle, která ničí lidi. Člověk je ubohý a bezmocný proti mašinérii.
      - *Motivy*: Bezvýchodná, paradoxní situace, absurdita, pocit viny a strachu, tísnivý zlý sen, odcizení člověka, neuchopitelný soud (na půdě baráku).
    ],
  ),
  literary-context: (
    umelecke-smer: [
      - *Existencialismus*: Uznávána je pouhá existence jedince. Život je starost, úzkost. Člověk se snaží najít svobodu v odcizeném světě.
      - *Expresionismus* a *Experimentální próza*: Narušení tradičního pojetí románu, potlačení dějové složky, prvky absurdity, nedodržení časové posloupnosti. Nejde o zobrazení vnější reality, ale vnitřního světa hrdiny. Využívá se podtext a subjektivnost.
      - *Surrealismus*: Osvobození představivosti od logiky, volné asociace (ovlivnil ho).
      Kafka je rovněž považován za předchůdce *absurdního dramatu*.
    ],
    historicke-souvislosti: [
      - 1. polovina 20. století, rozbouřená doba plná otřesů (zrychlování životního tempa, první světová válka, rozpad mnohonárodnostních říší, napjaté vztahy velmocí).
      - Dílo varuje před ideologickými režimy (předtucha fašismu a komunismu).
      - Kulturní život stál v protikladu k politice, vzniká meziválečná avantgarda (dadaismus, kubismus, futurismus atd.).
    ],
    soucasnici: [
      - *Franz Werfel*: Přítel světa, Jsme, Pavel mezi Židy, Kožlí zpěv, Verdi, Čtyřicet dnů, Sjezd Abiturientu.
      - *Gustav Meyrink*: Zelená tvář, Golem. (Vystihuje tajemnou atmosféru magické Prahy).
      - *Egon Ervín Kisch*: "Zuřivý reportér" (Pasák, Pražský pitaval).
      - *Max Brod*: Hlídka. (Kafkův přítel, který zachránil jeho dílo).
      - *Marcel Proust*: Hledání ztraceného času.
      - *James Joyce*: Odysseus.
      - *André Breton*: Nadja, Manifest surrealismu.
      - *Herman Hesse* (Stepní vlk), *Maxim Gorkij* (Měšťáci).
    ],
    autoruv-zivot: [
      - Žil v letech 1883–1924. Nejslavnější pražský německy píšící židovský spisovatel.
      - Narodil se na Starém Městě. Celý život trpěl složitým vztahem s otcem (galanterním obchodníkem), což v něm vyvolávalo pocity viny, nedostatečnosti a ztráty sebedůvěry (uzavírání se do vnitřního světa).
      - Vystudoval práva, od roku 1907 do 1922 pracoval v pojišťovně (práci nesnášel, od r. 1917 trpěl tuberkulózou). 
      - Prožíval rozpolcenost ohledně manželství (3x zasnouben).
      - Nepsal pro čtenáře, ale pro sebe; za jeho života vyšlo jen málo povídek. Před smrtí žádal Maxe Broda o spálení rukopisů, ten ale neuposlechl a posmrtně je vydal, přičemž musel určovat jejich chronologii.
      - Zemřel v rakouském léčebném ústavu.
    ],
    dalsi-dila: [
      - *Povídky*: Proměna (1912 - nejhumornější, absurdní vztah rodiny k Řehoři Samsovi).
      - *Romány (nedokončené)*: Nezvěstný, Zámek.
    ],
  ),
  kompozice: [
    - Rámcová kompozice ohraničená jedním rokem života od narozenin do narozenin hlavní postavy.
    - Děleno na dvě části: 1) Samostatný román "Proces", 2) Fragmenty a dodatky. Text obsahuje 10 kapitol, jejichž pořadí (i dalších nedokončených fragmentů) určil Max Brod. 
    - Zvláštností je, že Kafka nejprve napsal první a poslední kapitolu, až poté střed.
    - Kniha nemá silný dějový spád (ten přichází až na konci), je spíše rozborem psychiky. Sleduje chronologický postup (expozice, kolize, krize, peripetie, závěr), avšak kapitoly jsou řazeny volněji (tektonická i kauzální výstavba).
  ],
  obsah-dila: [
    Bankovní úředník Josef K. je v den svých 30. narozenin z neznámého důvodu ve svém bytě zatčen. Vše probíhá prapodivně.
    Josef neví o žádném provinění a snaží se před anonymním byrokratickým soudem (který sídlí například na půdách domů) obhájit svou nevinu. Postupně zjišťuje, že proces nelze zrušit a boj je marný.
    V chrámu si poslechne podobenství od duchovního o dveřích do zákona, díky němuž pochopí zbytečnost své bitvy a lživost zákona. Josef K. postupně ztrácí naději, rezignuje a nechá se pohltit absurdním systémem.
    V den svých 31. narozenin, aniž by byl vynesen jasný rozsudek, je odveden dvěma muži za město do lomu, kde rezignovaně, "jako pes", přijímá smrt ranou nožem do srdce.
  ],
  postavy: [
    Postavy jsou vykresleny mlhavě (nepřímá charakteristika), všechny se nachází v bezvýchodných situacích, jsou ponižovány a nikam nepatří.
    - *Josef K.*: Úspěšný prokurista v bance. Jeho život zasáhne neznámá vyšší síla. Zpočátku vinu odmítá, posléze pochybuje a nakonec proces pasivně přijímá. Provinil se tím, že připustil zmechanizování svého života. Autor neuvádí jeho celé jméno a chybí mu hlubší vnější charakteristika (pasivní hrdina).
    - *Náměstek ředitele*: Konkurent Josefa K. v bance, bere mu případy.
    - *Ženské postavy (celkem 6)*: *Elza* (prostitutka), *Slečna Burstnerová* (písařka, J.K. je do ní zamilovaný, na konci románu se objeví jako stín/symbol jiné cesty), *Lenka* (ošetřovatelka advokáta, s J.K. má poměr a radí mu), *Paní Grubačová* (lhostejná bytná), *Manželka posluhovače u soudu*, *Slečna Montagová*.
    - *Strýček z venkova*: Bývalý poručík a statkář. Zprostředkuje advokáta. (Autobiografický rys Kafkovy rodiny).
    - *Advokát Hulda*: Obhájce, jen nižší článek ve službách zkorumpovaného systému. 
    - *Malíř Titoreli*: Maluje pro soud i Josefa, vysvětluje mu absurdní druhy osvobození (skutečné, zdánlivé, průtah), z nichž ani jedno nevede k cíli.
    - *Obchodník Black*: Klient advokáta, ponížen na úroveň "advokátova psa".
    - *Duchovní ve velechrámu*: Vypráví o dveřích do zákona.
    - *Mrskači*: Vykonavatelé fyzických trestů šířící strach.
  ],
  vypravecsky-zpusob: [
    Er-forma. Vypravěč je striktně nezaujatý, chladně registrující a zcela lhostejný k osudu hlavní postavy.
  ],
  jazyk-dila: [
    - Styl je věcný, chladný a v kontrastu k hrůznému a absurdnímu obsahu.
    - Jazyk je spisovný, hutný, bez slangových a hovorových výrazů (neutrální slova). Využívají se odborné právnické termíny.
    - Slohové postupy: vyprávěcí, úvahový a podrobně popisný (vize, dlouhé odstavce s propracovanými detaily, které autor vzápětí problematizuje).
    - Převažují vnitřní monology nad dialogy. Dlouhá propracovaná souvětí.
    - Časté využití interpunkčních a syntaktických figur (asyndeton, apoziopeze, osamostatněný větný člen) a básnických prostředků (metafora, metonymie, personifikace, ironie osudu).
  ],
  ohlas-dila: [
    Chybí v dodaných poznámkách.
  ],
)