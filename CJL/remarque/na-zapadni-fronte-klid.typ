#import "../literature-template.typ": work

#work(
  title: "Na západní frontě klid",
  author: "Erich Maria Remarque",
  year: 1929,

  characteristics: (
    obsah: [
      Epika — próza
    ],
    utvary: [
      *Román s válečnou tematikou* — rozsáhlý příběh psaný prózou, hlavní i vedlejší dějové linie, vývoj postav. Naturalistické válečné scény, úvahové pasáže, dokumentárnost. Prolínají se dějové a úvahové části, závěr je uzavřený (smrtí vypravěče).
    ],
    name-meaning: [
      Ironický název — „klid" označuje místo největšího krveprolití. Pavel umírá právě v den, kdy vrchní velitelství hlásí: _„Na západní frontě klid, nic nového."_ Název předjímá hlavní myšlenku nesmysluplnosti války.
    ],
    tema: [
      Zachycení osudu generace německých chlapců odvlečených do války příliš brzy. Válka ničí jejich ideály, přátelství i schopnost žít normálním životem.

      *Motivy:* válka, přátelství mezi vojáky, konflikt mládí a smrti, drsnost doby, snaha přežít, změna hodnot a priorit, neschopnost začlenit se do společnosti po návratu z fronty.
    ],
  ),

  literary-context: (
    umelecke-smer: [
      *Ztracená generace* — generační skupina autorů (zejména amerických) 20. let 20. stol. poznamenanych duchovním otřesem z prožité 1. světové války. Pojem připisován Gertrudě Steinové. Typické rysy: neschopnost začlenit se do společnosti, pocity zklamání, skepse, apatičnost, nedůvěra ke společnosti. Styl blízký novinářskému, hrdinové stavěni do mezních situací.

      *Realismus* (18.–19. stol., přesahuje do 20. stol.) — nezkrácené zachycení skutečnosti, zavrhnutí útěku do snů, hrdina je průměrný člověk procházející vývojem, hovorový jazyk, dialekty, archaismy. Žánry: román, povídka, drama.
    ],
    historicke-souvislosti: [
      Kniha vydána 1929 (nevázané vydání 1928), během roku přes dva miliony výtisků. Po nástupu nacismu (1933) prohlášena za zakázanou a hromadně pálena. Nacistická propaganda označila Remarquea za Žida (_Paul Kramer = Remark pozpátku_) a „literárního zrádce". Jeho sestra zahynula za 2. světové války v koncentračním táboře. Filmová adaptace 1930 — dva Oscary; adaptace 1979 (režie Delbert Mann) — exteriéry natáčeny v demolovaném Mostě v Československu.
    ],
    soucasnici: [
      - Ernest Hemingway — _Stařec a moře_
      - Francis Scott Fitzgerald — _Velký Gatsby_
      - Romain Rolland — _Petr a Lucie_
      - Bertolt Brecht — _Matka Kuráž a její děti_
      - Lion Feuchtwanger — _Lišky na vinici_
      - Jaroslav Hašek — _Osudy dobrého vojáka Švejka_
    ],
    autoruv-zivot: [
      *Erich Paul Remark* (1898–1970), německý prozaik a dramatik. Syn vazače knih, původně chtěl být hudebníkem a malířem. Roku 1916 narukoval jako 18letý dobrovolník na západní frontu, byl raněn a zbytek války prožil v nemocnici. Po válce vystřídal řadu povolání — učitel, varhaník, automobilový závodník, obchodní cestující, redaktor. Roku 1931 emigroval do Švýcarska, 1938 zbaven německého občanství, 1939 odjel do New Yorku (americké občanství). Po válce se vrátil do Švýcarska, zemřel na srdeční chorobu. Ceněn pro humanistický náboj děl, vytýkána mu šablonovitost a vykonstruované zápletky.
    ],
    dalsi-dila: [
      - _Cesta zpátky_ — volné pokračování, začlenění do společnosti po frontě
      - _Tři kamarádi_ — osudy tří přátel s autodílnou
      - _Vítězný oblouk_ — německý chirurg a pomsta
      - _Jiskra života_ — inspirováno smrtí sestry v koncentračním táboře
      - _Miluj bližního svého_
      - _Černý obelisk_
    ],
  ),

  kompozice: [
    12 kapitol, chronologický děj s prvky *retrospektivy* (Pavlovy vzpomínky na domov). Psáno *ich-formou* — vypravěčem je Pavel Bäumer; závěrečný odstavec oznamující jeho smrt přechází do *er-formy*. Gradace díla, střídání dějových a úvahových pasáží.

    *Časoprostor:* západní fronta, hranice Francie a Německa, období 1. světové války (1914–1918), příběh končí na podzim 1918 těsně před příměřím.
  ],

  obsah-dila: [
    Student gymnázia *Pavel Bäumer* se spolu se spolužáky pod nátlakem vlasteneckého profesora *Kantorka* dobrovolně přihlásí na frontu. Počáteční ideály rychle rozbije šikanující výcvik pod desátníkem *Himmelstossem* a následná realita zákopové války — plynové útoky, bombardování, smrt přátel.

    Oporou skupiny je ostřílený *Stanislav Katczinsky* („Katza"), nejstarší z party, který vždy sežene jídlo a poradí si v každé situaci. Pavel postupně ztrácí všechny kamarády. Na dovolené zjistí, že matka umírá na rakovinu a s okolním světem nedokáže nalézt společnou řeč — vrací se na frontu jako na jediné místo, kde rozumí životu.

    Zlomovým okamžikem je boj muže proti muži, při němž Pavel smrtelně zraní francouzského vojáka a dva dny s ním stráví v trychtýři s výčitkami svědomí. Největší ranou je smrt Katczinského — zasažen střepinou, když ho Pavel odnáší z bojiště.

    Na podzim 1918 zůstává Pavel poslední naživu ze svých spolužáků. Vnitřně prázdný a unavený, netečný i ke zprávám o příměří. Umírá v říjnu 1918 — v den, kdy vrchní velitelství hlásí klid na západní frontě.
  ],

  postavy: [
    - *Pavel Bäumer* — hlavní hrdina a vypravěč, 20letý student gymnázia. Zpočátku plný ideálů, válka ho postupně psychicky ničí. Na konci není schopen představit si normální život.
    - *Stanislav Katczinsky* — „Katza", ~40letý Polák, vedoucí skupiny, vždy sežene jídlo, spravedlivý, pro Pavla víc než bratr. Umírá zasažen střepinou.
    - *Albert Kropp* — Pavlův spolužák, po amputaci nohy prohlásí, že nemá smysl žít.
    - *Müller* — spolužák, nosí s sebou učebnice, sní o „válečné maturitě", zabije ho světlice do žaludku.
    - *František Kemmerich* — umírá na začátku knihy, odkazuje boty Müllerovi.
    - *Tjaden* — největší rebel a jedlík, lehce uniká problémům.
    - *Deterding* — sedlák, myslí jen na ženu a usedlost, prchne z fronty, je zadržen.
    - *Himmelstoss* — desátník, v civilu listonoš, sadistický velitel výcviku, nakonec vojákům nabídne smír.
    - *Kantorek* — třídní profesor, propagandou přesvědčí žáky k narukování.
    - *Anselm* — _(není v tomto díle, vynechat)_
  ],

  vypravecsky-zpusob: [
    *Ich-forma* — vypravěčem je Pavel Bäumer. Po jeho smrti přechází závěrečný odstavec do *er-formy*. Střídá se pásmo vypravěče a pásmo postav (dialogy vojáků). Časté úvahové monology.
  ],

  jazyk-dila: [
    Spisovný jazyk s hovorovými výrazy a *vojenským slangem* (švindl, brajgl, palice). Vulgární výrazy zvyšují napětí. *Naturalistické* popisy zranění a smrti. Ironie (vyplývá z názvu). Gradace, perifráze, výčet, epizeuxis, archaismy. Časté dialogy i úvahové pasáže. Ich-forma přechází v er-formu.
  ],

  ohlas-dila: [
    Během roku od vydání (1929) přes 2 miliony výtisků. Po nástupu nacismu (1933) zakázána a pálena. Filmová adaptace 1930 — *2 Oscary*. Adaptace 1979 (Delbert Mann) — natáčeno částečně v demolovaném Mostě v Československu. Remarque ceněn pro humanistický postoj a nekompromisní antifašismus, kritizován za šablonovitost.
  ],
)