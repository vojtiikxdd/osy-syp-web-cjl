#import "../literature-template.typ": work

#work(
  title: "Proměna",
  author: "Franz Kafka",
  year: "Chybí",
  characteristics: (
    obsah: [
      Próza.
    ],
    utvary: [
      Epika, povídka.
    ],
    name-meaning: [
      Vyjadřuje odcizení, izolaci a bezmocnost člověka v moderním světě. Zároveň může být interpretována jako metafora pro pocity viny, úzkosti a deprese.
    ],
    tema: [
      Vývoj vztahů v rodině po Řehořově proměně – odcizení.
    ],
  ),
  literary-context: (
    umelecke-smer: [
      Existencialismus a expresionismus.
      - *Existencialismus*: Cílem života je smrt, klade důraz na individualismus. Do života jsme nesvobodně vrženi a naše nesvoboda spočívá v nutnosti rozhodování se. Svými činy sami ovlivňujeme svůj život.
      - *Expresionismus*: Vznikl jako protiklad impresionismu a naturalismu, odmítl umění zobrazující skutečnost i umění snažící zprostředkovat skutečnost pomocí dojmů. Hlavním cílem je vyjádřit vlastní prožitky a pocity. Pro zvýšení efektu prožitku často dochází k deformaci reality.
    ],
    historicke-souvislosti: [
      Chybí v dodaných poznámkách.
    ],
    soucasnici: [
      - *Gustav Meyrink*: Golem.
      - *Rainer Maria Rilke*: Kniha hodinek, Sonety Orfeovi, Duinské elegie.
      - *Franz Werfel*: Čtyřicet dnů, Pavel mezi Židy, Kozlí zpěv, Verdi, Hvězda nenarozených.
      - *Egon Ervín Kisch*: Zuřivý reportér, Pasák, Pražská dobrodružství, Pražský pitaval.
    ],
    autoruv-zivot: [
      - Narozen na Starém Městě v Praze, psal německy, mluvil česky a francouzsky.
      - Studoval práva a seznámil se s Maxem Brodem, se kterým navázal celoživotní přátelství.
      - Pracoval v pojišťovně jako tajemník a zajímal se o českou politiku.
      - Od roku 1917 měl tuberkulózu hrtanu, kvůli které nemohl mluvit a polykat, pobýval v sanatoriích.
      - V závěti vyslovil přání, aby Max Brod zničil všechna nepublikovaná díla, což Brod neuposlechl.
      - Zemřel v sanatoriu a je pohřben na Novém židovském hřbitově na Žižkově.
    ],
    dalsi-dila: [
      - Tři nedokončené romány: Proces, Zámek, Nezvěstný/Amerika.
      - Deníky (používal je jako skicáře) a tisíce dopisů.
    ],
  ),
  kompozice: [
    - Děleno na tři části: 1. všichni se vyrovnávají se situací, 2. dočasný způsob společného žití, 3. odcizení.
    - Chronologický postup s občasným vzpomínáním.
    - Úvodní souvětí informuje o situaci.
  ],
  obsah-dila: [
    - Čas není udán, děj se odehrává hlavně v pokoji maloměstského bytu Řehořovy rodiny v nejmenovaném městě.
    - Řehoř Samsa se probudí proměněn ve velký hmyz, kvůli čemuž nestihne vlak a nesplní pracovní úkol.
    - Rodina se zhrozí; sestra se o něj nejprve stará, ale postupně v něm začne vidět jen hmyz, přestože Řehoř myslí a cítí jako člověk.
    - Matka při pohledu na něj omdlévá a otec ho zraní hozeným jablkem.
    - Řehoř vyděsí nájemníky i uklízečku, pochopí, že překáží, a umírá.
    - Rodina má z jeho smrti radost a zapomene na něj.
    - Hlavní myšlenky díla jsou trest, odcizení, povrchnost společnosti a smrt.
  ],
  postavy: [
    - *Řehoř Samsa*: Cestující obchodník, svědomitý živitel rodiny. Po proměně nepřemýšlí proč k ní došlo, řeší jen pozdní příchod do práce, smířeně a s pokorou snáší odpor rodiny.
    - *Markétka*: Řehořova sedmnáctiletá a hudebně nadaná sestra. Zprvu bratra lituje a stará se o něj, později však musí pracovat, bratr se pro ni stane přítěží a začne ho nenávidět.
    - *Matka*: Zpočátku si myslí, že stav je přechodný, avšak při konfrontaci se vyděsí k hrůze. Syn se pro ni stane nenáviděným břemenem.
    - *Otec*: Vyhýbá se kontaktu, odhání ho, syn je mu odporný.
    - *Gréta*: Posluhovačka, opovrhuje jím a nazývá ho pouze "to".
    - *Další postavy*: Nájemníci, pan prokurátor.
  ],
  vypravecsky-zpusob: [
    Chybí v dodaných poznámkách.
  ],
  jazyk-dila: [
    - Spisovný jazyk, neutrální slova, prostý a věcný styl.
    - Občas se objevují přechodníky a paradoxní slovní spojení.
    - Tropy a figury: vulgarismus, eufemismus, hyperbola, řečnická otázka.
  ],
  ohlas-dila: [
    Chybí v dodaných poznámkách.
  ],
)