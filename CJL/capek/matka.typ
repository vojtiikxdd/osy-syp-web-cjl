#import "../literature-template.typ": work

#work(
  title: "Matka",
  author: "Karel Čapek",
  year: 1938,
  characteristics: (
    obsah: [Drama (protiválečné).],
    utvary: [Drama o 3 dějstvích. Hra je členěna na jednání a obrazy (využívá klasické schéma: expozice, kolize, krize, peripetie, katastrofa).],
    name-meaning: [
      Odkazuje k hlavní postavě a ústřední myšlence – války berou matkám děti a matky trpí. Sama hlavní postava - matka Dolores - je zosobněním mateřství, které je v kontrastu s mužskou touhou po slávě a hrdinství, bojuje za své a o své děti.
    ],
    tema: [
      - Odsouzení války a její nesmyslnost (ničí lidské hodnoty a životy, staví proti sobě i nejbližší rodinu, bere matkám děti).
      - Kontrast mužského a ženského pohledu na svět (mužská touha po slávě a hrdinství vs. ženský důraz na lásku a uchování života).
      - Pasivitou nelze zachránit ohrožený národ. Válka má smysl pouze tehdy, bráníme-li nevinné lidi.
      - Zbytečná úmrtí, varování před válkou (nadčasovost) a prolínání světa živých a mrtvých.
    ],
  ),
  literary-context: (
    umelecke-smer: [
      - Meziválečná próza – demokratický proud (okruh redakce Lidových novin).
      - Vychází z pragmatismu (pravdivé je to, co je prakticky užitečné; pluralita a relativita pravd).
      - Autoři jsou humanisté, liberálové (blízcí "hradnímu křídlu" a TGM), zaměřují se na obyčejného člověka, jeho každodenní život a vystupují protifašisticky.
      - Nechtějí odstraňovat nedostatky revolucemi, ale reformami.
    ],
    historicke-souvislosti: [
      - 30. léta 20. století. Období tzv. první republiky (zlatá léta, rozmach ČSR za prezidentů Masaryka a Beneše) střídá hospodářská krize a nástup Hitlera k moci v Německu.
      - Rostoucí tlak na ČSR, budování pohraničního opevnění, politika usmiřování ústící v Mnichovskou dohodu a 2. republiku.
      - Dílo je přímo inspirováno španělskou občanskou válkou.
      - Česká literatura ztrácí vlastenecké poslání a rozvíjí estetickou funkci.
    ],
    soucasnici: [
      - *Demokratický proud*: Josef Čapek (bratr – Stín kapradiny), Karel Poláček (Bylo nás pět, Muži v ofsajdu), Eduard Bass (Cirkus Humberto, Klapzubova jedenáctka).
      - *Další české směry*: Proletářská poezie (J. Wolker, V. Nezval, J. Seifert), Legionářská literatura (J. Hašek, F. Langer), Imaginativní próza (V. Vančura), Levicově orientovaná próza (I. Olbracht, M. Majerová), Psychologická próza (J. Havlíček, V. Řezáč), Ruralismus.
      - *Světová literatura (ztracená generace atd.)*: E. Hemingway (Stařec a moře), E. M. Remarque (Na západní frontě klid), R. Rolland, J. Steinbeck, F. Kafka.
    ],
    autoruv-zivot: [
      - Žil v letech 1890–1938. Nejvýznamnější představitel demokratického proudu, humanista a pragmatik, syn lékaře z Malých Svatoňovic.
      - Vystudoval filozofii (doktorát z estetiky). Pracoval jako novinář (Národní listy, Lidové noviny), kde přispěl k rozvoji fejetonu a sloupku. Působil i jako dramaturg Vinohradského divadla.
      - Přátelil se s T. G. Masarykem (napsal *Hovory s TGM*).
      - Obdivoval vědu a techniku, ale bál se, aby neovládla člověka. Miloval lidi, věřil v lidský rozum.
      - Kvůli svým postojům a varování před válkou byl terčem fašistů. Po Mnichovské dohodě nechtěl dál žít a zemřel v prosinci 1938.
      - Matka odkazuje na nebezpeci valky spis nez na nebezceci fašismu, protoze valka bere deti a matky trpi, zatimco fašismus bere _jen_ svobodu a demokracii.
    ],
    dalsi-dila: [
      - *Dramata*: R.U.R., Věc Makropulos, Bílá nemoc, Loupežník, Ze života hmyzu (s bratrem).
      - *Romány a povídky*: Továrna na absolutno, Krakatit, Válka s mloky, Trapné povídky, Povídky z jedné a druhé kapsy, První parta. Noetická trilogie (Hordubal, Povětroň, Obyčejný život).
      - *Cestopisy*: Italské listy, Anglické listy, Výlet do Španěl.
      - *Tvorba pro děti*: Dášeňka čili život štěněte, Devatero pohádek.
      - *S bratrem Josefem*: Zářivé hlubiny, Krakonošova zahrada.
    ],
  ),
  kompozice: [
    Pevná kompozice tradičního dramatu. Hra o 3 dějstvích, psaná chronologicky a členěná na jednání a obrazy. Jedná se o autorovo poslední dílo.
  ],
  obsah-dila: [
    Děj se odehrává v pokoji s uschovanými zbraněmi a předměty po zesnulých, kam Dolores chodí rozmlouvat se svým mrtvým manželem Richardem (padl nesmyslně kvůli špatnému rozkazu v Africe) a synem Ondřejem (zemřel na žlutou zimnici).
    - *1. dějství*: Dozvídáme se, že rodinu tvoří 5 synů. Nejstarší Ondra už zemřel. Další syn, letec Jiří, vstoupí do pokoje, vidí své mrtvé příbuzné a přiznává matce, že jeho letadlo právě spadlo – rozšíří tak řady duchů.
    - *2. dějství*: Probíhá občanská válka (bílí vs. černí). Dvojčata Petr a Kornel stojí na opačných stranách barikády. Petr je zatčen a posléze zastřelen, brzy na to umírá i Kornel. Oba se jako duchové vrací do pokoje matky. Otec a synové se shodují, že zemřeli jako hrdinové.
    - *3. dějství*: Vypukne mezinárodní konflikt a země je napadena nepřítelem. Rádio vyzývá všechny muže i ženy k obraně. Poslední žijící syn, citlivý básník Toni, chce jít bojovat. Matka ho zamyká a zuřivě ho odmítá pustit, hádá se s duchy manžela, synů i dědečka, kteří si myslí, že by Toni (ačkoliv jím opovrhují pro jeho slabost) měl splnit svou povinnost. Matka je neoblomná, dokud z rádia neuslyší hlasatelku (která sama ztratila syna na lodi Gorgona) oznamující, že nepřítel bombardoval školu plnou malých dětí. Matka si uvědomí hrůzu umírání nevinných, strhne ze stěny pušku, podá ji Tonimu a řekne jediné slovo: „Jdi.“
  ],
  postavy: [
    - *Matka Dolores*: Citlivá, starostlivá, smyslem jejího života byla její rodina. Neoblomná odpůrkyně války.
    - *Otec Richard*: Bývalý důstojník, zahynul v Africe kvůli špatnému rozkazu a vlastní hrdosti.
    - *Ondra*: Syn, lékař, obětoval se pro vědu (nechal se štípnout infikovaným komárem při léčbě žluté zimnice).
    - *Jiří*: Syn, letec, zemřel při pokusu o překonání výškového rekordu.
    - *Petr*: Syn (dvojče Kornela), levicový buřič (černí), popraven za své politické názory.
    - *Kornel*: Syn (dvojče Petra), bojoval za stranu národa (bílí), padl v boji.
    - *Toni*: Nejmladší syn, velmi citlivý, jemný a vnímavý. Píše básně, nepoznal otce.
    - *Dědeček*: Duch, se kterým matka rozmlouvá ve třetím dějství.
  ],
  vypravecsky-zpusob: [
    er-forma, jedná se o drama, příběh je posouván výhradně prostřednictvím dialogů postav a scénických poznámek).
  ],
  jazyk-dila: [
    - Jazyk je spisovný, místy hovorový.
    - Časté využití zvolacích vět, nedokončených výpovědí a převzatých cizích výrazů.
    - V textu jsou dlouhé, emocionální pasáže, ve kterých matka náruživě líčí své pocity a utrpení.
    - Součástí díla jsou scénické poznámky a důležitou roli hraje "hlas z amplionu" (rozhlas), který promlouvá k divákovi i postavám (ztotožňuje se s matkou, volá mladé muže do války).
  ],
  ohlas-dila: [
    Premiéra proběhla v únoru 1938 v Národním divadle.
    Hra byla hojně inscenována a hrála se v Národním, Stavovském i Tylově divadle.
  ],
)